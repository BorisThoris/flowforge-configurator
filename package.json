    "i18next-browser-languagedetector": "^5.0.0",
    "react": "^16.13.1",
    "react-dom": "^16.13.1",
    "react-i18next": "^11.7.0",
    "react-redux": "^7.2.0",
    "react-redux-i18n": "^1.9.3",
    "react-scripts": "3.4.1",
    "redux": "^4.0.5",
